# Based on https://github.com/elastic/elasticsearch/blob/main/docs/reference/setup/install/docker/.env

# Password for the 'elastic' user (at least 6 characters)
ELASTIC_PASSWORD=elastic

# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_PASSWORD=kibana

# Version of Elastic products
STACK_VERSION=9.3.2

# Set the cluster name
CLUSTER_NAME=docker-cluster

# Set to 'basic' or 'trial' to automatically start the 30-day trial
LICENSE=basic
#LICENSE=trial

# Subnet for the Docker network
ES_SUBNET=172.20.0.0/24

# Port to expose Elasticsearch HTTP API to the host
ES_PORT=9200
#ES_PORT=127.0.0.1:9200

# Port to expose Kibana to the host
KIBANA_PORT=5601

# NOTE: Run `bin/kibana-encryption-keys` inside Kibana container to generate the keys
# NB! Make sure to change these values to your own values
KIBANA_ENCRYPTED_SAVED_OBJECTS_ENCRYPTION_KEY=1aeb0a397de2e73b24c206a497b107f5c607c0d8893c1403e44a8c524e345ec0
KIBANA_REPORTING_ENCRYPTION_KEY=a028d06384258b133c237fb73fb215b6640dd3d000dd650058d4eae4607548e4
KIBANA_SECURITY_ENCRYPTION_KEY=f0149a34648f51af11a00be56261da74dcd1014fa46d98957b13a8177de522d4

# Increase or decrease based on the available host memory (in bytes)
# 1 GiB = 1073741824, 2 GiB = 2147483648
# MEM_LIMIT=1073741824
ES_MEM_LIMIT=1073741824
KB_MEM_LIMIT=1073741824
LS_MEM_LIMIT=1073741824

# Project namespace (defaults to the current folder name if not set)
COMPOSE_PROJECT_NAME=elastic
